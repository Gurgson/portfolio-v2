jstapinski.eu {
	encode gzip zstd
	reverse_proxy portfolio:3000
}

# Opcjonalny redirect www -> apex
www.jstapinski.eu {
	redir https://jstapinski.eu{uri}
}

czytnik.jstapinski.eu {
	encode gzip zstd
	reverse_proxy czytnik:8080
}
