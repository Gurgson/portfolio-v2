# Automatyczny HTTPS (Let's Encrypt). DNS jstapinski.eu + subdomeny -> IP VPS.
{
	email jaksta65@gmail.com
}

jstapinski.eu {
	encode gzip zstd
	reverse_proxy portfolio:3000
}

# www -> apex
www.jstapinski.eu {
	redir https://jstapinski.eu{uri} permanent
}

# Placeholder Czytnika (docelowo kontener .NET)
czytnik.jstapinski.eu {
	encode gzip zstd
	# Kontener Czytnika (własne repo/compose) w sieci `edge`; `czytnik` to alias
	# serwisu nadawany przez compose. Statyczny placeholder leży w deploy/czytnik
	# — zostaje na wypadek gdyby trzeba było wrócić.
	reverse_proxy czytnik:8080
}
