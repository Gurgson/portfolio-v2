# Wzór zmiennych środowiskowych. Na VPS: /opt/portfolio-v2/.env (root repo).
# Ładowane do kontenera przez `env_file: ../.env`. NIE trafia do repo (.gitignore).

# --- Postgres NATYWNY na hoście ---
# Aplikacja (w Dockerze) łączy się przez host.docker.internal (extra_hosts w compose).
# Rola read-only portfolio_app; hasła/role ustawiane bezpośrednio na hoście (psql).
# Bez sslmode (połączenie lokalne host<->kontener).
DATABASE_URL=postgresql://portfolio_app:haslo_app@host.docker.internal:5432/portfolio
# UWAGA: na czas migracji z Neona trzymaj tu tymczasowo URL Neona,
# a przełącz DOPIERO po przeniesieniu danych.

# --- Formularz kontaktowy (Gmail SMTP) ---
# GMAIL_APP_PASSWORD: 16-znakowe "hasło aplikacji" Google (nie hasło do konta),
#   z https://myaccount.google.com/apppasswords (wymaga 2FA).
GMAIL_USER=twoj.adres@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
