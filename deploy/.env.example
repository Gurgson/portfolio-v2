# Wzór zmiennych środowiskowych aplikacji.
# Na VPS skopiuj do /opt/portfolio-v2/.env (root repo) i uzupełnij.
# docker-compose ładuje ten plik przez `env_file: ../.env`.
# Plik .env NIE trafia do repo (jest w .gitignore).

# Postgres (na razie Neon, SSL wymagany)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Formularz kontaktowy — wysyłka przez Gmail SMTP (nodemailer)
# GMAIL_USER: Twój adres Gmail (konto, z którego wychodzi mail)
# GMAIL_APP_PASSWORD: 16-znakowe "hasło aplikacji" Google (NIE hasło do konta),
#   wygenerowane na https://myaccount.google.com/apppasswords (wymaga 2FA).
GMAIL_USER=twoj.adres@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
